{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build"
  },
  "deploy": {
    "startCommand": "PROJECT_DIR=./demo-projects DEFAULT_PROJECT=metamorphosis bash start.sh",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
